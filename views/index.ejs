<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Chess</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/themes.css">
</head>
<body class="theme-modern text-white m-0 p-0 overflow-x-hidden w-screen min-h-screen relative flex items-center justify-center bg-zinc-900">

    <div id="toast" class="fixed top-10 left-1/2 transform -translate-x-1/2 bg-red-600 text-white px-8 py-3 rounded shadow-2xl font-bold text-2xl transition-opacity duration-300 opacity-0 pointer-events-none z-[100]">
        Check!
    </div>

    <div id="startModal" class="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50 transition-opacity duration-300">
        <div class="bg-gray-800 p-8 rounded-xl w-[400px] shadow-2xl border border-gray-600">
            <h1 class="text-3xl font-bold text-white mb-6 text-center">Chess Settings</h1>
            
            <div class="mb-4">
                <label class="block text-gray-300 mb-2 font-bold">Theme</label>
                <select id="themeSelect" class="w-full p-3 bg-gray-700 rounded text-white outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="modern">Modern Glass</option>
                    <option value="traditional">Traditional Wood</option>
                </select>
            </div>

            <div class="mb-6">
                <label class="block text-gray-300 mb-2 font-bold">Game Mode</label>
                <select id="modeSelect" onchange="toggleModeUI()" class="w-full p-3 bg-gray-700 rounded text-white outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="single">Vs Computer (Offline)</option>
                    <option value="random">Online: Random Match</option>
                    <option value="create_private">Online: Create Private Room</option>
                    <option value="join_private">Online: Join Private Room</option>
                </select>
            </div>

            <div id="difficultyContainer" class="mb-6 block">
                <label class="block text-gray-300 mb-2 font-bold">Bot Difficulty</label>
                <select id="diffSelect" class="w-full p-3 bg-gray-700 rounded text-white outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="easy">Easy </option>
                    <option value="medium">Medium</option>
                    <option value="hard">Hard</option>
                </select>
            </div>

            <div id="joinRoomContainer" class="mb-6 hidden">
                <label class="block text-gray-300 mb-2 font-bold">Enter Room Code</label>
                <input type="text" id="roomCodeInput" placeholder="e.g., a1b2c3" class="w-full p-3 bg-gray-700 rounded text-white outline-none focus:ring-2 focus:ring-indigo-500 font-mono text-center tracking-widest uppercase">
            </div>

            <button onclick="startGame()" class="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded transition shadow-lg text-lg mt-2">
                Play Game
            </button>
        </div>
    </div>

    <div id="promotionModal" class="fixed inset-0 bg-black bg-opacity-70 hidden items-center justify-center z-50">
        <div class="bg-gray-800 p-6 rounded-xl text-center shadow-2xl border border-gray-600">
            <h2 class="text-2xl font-bold mb-4">Promote Pawn</h2>
            <div class="flex gap-4 justify-center text-5xl">
                <button onclick="promotePiece('q')" class="p-4 bg-gray-700 hover:bg-indigo-500 rounded cursor-pointer transition">♛</button>
                <button onclick="promotePiece('r')" class="p-4 bg-gray-700 hover:bg-indigo-500 rounded cursor-pointer transition">♜</button>
                <button onclick="promotePiece('b')" class="p-4 bg-gray-700 hover:bg-indigo-500 rounded cursor-pointer transition">♝</button>
                <button onclick="promotePiece('n')" class="p-4 bg-gray-700 hover:bg-indigo-500 rounded cursor-pointer transition">♞</button>
            </div>
        </div>
    </div>

    <div class="w-full max-w-6xl flex flex-col md:flex-row items-center justify-center gap-12 p-6">
        
        <div class="chessboard-container relative shadow-[0_0_40px_rgba(0,0,0,0.5)] rounded-lg">
            <div id="waitingOverlay" class="absolute inset-0 z-10 bg-black bg-opacity-80 flex flex-col items-center justify-center rounded hidden backdrop-blur-sm">
                <span id="overlayText" class="bg-gray-900 px-6 py-3 border border-gray-700 rounded text-white font-bold text-lg shadow-xl mb-4">Waiting...</span>
                <span id="roomCodeDisplay" class="hidden text-3xl font-mono tracking-widest text-indigo-400 bg-gray-900 px-6 py-2 border border-indigo-500 rounded shadow-[0_0_15px_rgba(99,102,241,0.5)] cursor-text select-all"></span>
            </div>
            <div class="chessboard"></div>
        </div>

        <div class="flex flex-col gap-6 w-full max-w-sm bg-gray-800/90 backdrop-blur-md p-6 rounded-2xl shadow-2xl border border-gray-700">
            
            <div id="playerStatus" class="text-xl font-bold text-center text-white bg-gray-900 py-3 rounded-lg border border-gray-600 shadow-inner">
                Setup...
            </div>

            <div class="flex justify-between items-center gap-4 my-2">
                <div class="flex flex-col items-center justify-center bg-gray-100 text-black py-4 rounded-xl shadow-lg w-full">
                    <span class="text-xs font-bold uppercase text-gray-500 tracking-wider mb-1">White</span>
                    <div id="timerW" class="font-mono text-3xl font-bold">10:00</div>
                </div>
                <div class="flex flex-col items-center justify-center bg-gray-900 text-white py-4 rounded-xl shadow-lg border border-gray-600 w-full">
                    <span class="text-xs font-bold uppercase text-gray-400 tracking-wider mb-1">Black</span>
                    <div id="timerB" class="font-mono text-3xl font-bold">10:00</div>
                </div>
            </div>

            <div id="gameStatus" class="text-xl font-bold text-center text-yellow-400 min-h-[3.5rem] flex items-center justify-center bg-gray-900/60 rounded-lg p-2 border border-gray-700/50">
                Select Game Mode...
            </div>

            <div class="grid grid-cols-2 gap-4 w-full mt-2">
                <button id="undoBtn" onclick="requestUndo()" class="hidden w-full bg-blue-600 hover:bg-blue-500 text-white py-3 rounded-lg shadow-lg transition font-bold text-lg border border-blue-700">
                    Undo
                </button>
                <button id="restartBtn" onclick="requestRestart()" class="hidden w-full bg-amber-600 hover:bg-amber-500 text-white py-3 rounded-lg shadow-lg transition font-bold text-lg border border-amber-700">
                    Restart
                </button>
            </div>
        </div>

    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>